{
  "info": {
    "name": "Cracks API — TP Final Backend (UTN)",
    "description": "Coleccion de la API REST de CracksApp (Node + Express + MongoDB).\n\nUso: la variable `baseUrl` ya apunta al deploy publico (para local, cambiala a http://localhost:3000). Corre la coleccion en orden (Runner) o de arriba hacia abajo: **Login** guarda el token, y los pasos de creacion (grupo, chat, mensaje, estado) guardan sus ids automaticamente para los pasos siguientes.\n\nUsuario de prueba (email verificado): cracks.tp.utn@gmail.com / Cracks2026!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://cracks-backend.onrender.com" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "contactId", "value": "" },
    { "key": "groupId", "value": "" },
    { "key": "conversationId", "value": "" },
    { "key": "messageId", "value": "" },
    { "key": "statusId", "value": "" }
  ],
  "item": [
    {
      "name": "General",
      "item": [
        {
          "name": "Raiz (info API)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] } }
        },
        {
          "name": "Health",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] } }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nuevo@ejemplo.com\",\n  \"password\": \"Password1\",\n  \"display_name\": \"Usuario Nuevo\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Verify email",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/auth/verify-email?token=TOKEN_DEL_EMAIL", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-email"], "query": [{ "key": "token", "value": "TOKEN_DEL_EMAIL" }] } }
        },
        {
          "name": "Login (guarda el token)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('login 200', () => pm.expect(pm.response.code).to.eql(200));",
            "const d = pm.response.json();",
            "if (d && d.data && d.data.access_token) { pm.collectionVariables.set('token', d.data.access_token); }"
          ] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"cracks.tp.utn@gmail.com\",\n  \"password\": \"Cracks2026!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Forgot password",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"cracks.tp.utn@gmail.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"TOKEN_DEL_EMAIL\",\n  \"password\": \"NuevaClave1\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-password"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Buscar usuarios",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/users?q=ar", "host": ["{{baseUrl}}"], "path": ["api", "users"], "query": [{ "key": "q", "value": "ar" }] } }
        },
        {
          "name": "Editar mi perfil",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status_message\": \"Disponible\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
          }
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "Listar contactos (guarda userId)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.expect(pm.response.code).to.eql(200));",
            "const d = pm.response.json();",
            "const arr = (d && d.data && d.data.contacts) || [];",
            "if (arr[0] && arr[0].contact_user_id) {",
            "  const u = arr[0].contact_user_id;",
            "  pm.collectionVariables.set('userId', u._id || u);",
            "}"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/contacts", "host": ["{{baseUrl}}"], "path": ["api", "contacts"] } }
        },
        {
          "name": "Agregar contacto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"contact_user_id\": \"{{userId}}\",\n  \"alias\": \"Alias opcional\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/contacts", "host": ["{{baseUrl}}"], "path": ["api", "contacts"] }
          }
        },
        {
          "name": "Editar contacto (requiere contactId real)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"is_favorite\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/contacts/{{contactId}}", "host": ["{{baseUrl}}"], "path": ["api", "contacts", "{{contactId}}"] }
          }
        },
        {
          "name": "Eliminar contacto (requiere contactId real)",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/contacts/{{contactId}}", "host": ["{{baseUrl}}"], "path": ["api", "contacts", "{{contactId}}"] } }
        }
      ]
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "Crear grupo (guarda groupId)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.expect(pm.response.code).to.eql(201));",
            "const d = pm.response.json();",
            "if (d && d.data && d.data.group) { pm.collectionVariables.set('groupId', d.data.group._id || d.data.group.id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Grupo de prueba\",\n  \"description\": \"Creado desde Postman\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/groups", "host": ["{{baseUrl}}"], "path": ["api", "groups"] }
          }
        },
        {
          "name": "Listar mis grupos",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/groups", "host": ["{{baseUrl}}"], "path": ["api", "groups"] } }
        },
        {
          "name": "Detalle de grupo",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/groups/{{groupId}}", "host": ["{{baseUrl}}"], "path": ["api", "groups", "{{groupId}}"] } }
        },
        {
          "name": "Editar grupo",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Grupo editado\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/groups/{{groupId}}", "host": ["{{baseUrl}}"], "path": ["api", "groups", "{{groupId}}"] }
          }
        },
        {
          "name": "Agregar miembro",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('2xx', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{userId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/groups/{{groupId}}/members", "host": ["{{baseUrl}}"], "path": ["api", "groups", "{{groupId}}", "members"] }
          }
        },
        {
          "name": "Quitar miembro",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/groups/{{groupId}}/members/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "groups", "{{groupId}}", "members", "{{userId}}"] } }
        },
        {
          "name": "Eliminar grupo",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/groups/{{groupId}}", "host": ["{{baseUrl}}"], "path": ["api", "groups", "{{groupId}}"] } }
        }
      ]
    },
    {
      "name": "Conversations & Messages",
      "item": [
        {
          "name": "Listar mis chats",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/conversations", "host": ["{{baseUrl}}"], "path": ["api", "conversations"] } }
        },
        {
          "name": "Abrir chat privado (guarda conversationId)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.expect(pm.response.code).to.eql(200));",
            "const d = pm.response.json();",
            "if (d && d.data && d.data.conversation) { pm.collectionVariables.set('conversationId', d.data.conversation._id || d.data.conversation.id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{userId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/conversations/private", "host": ["{{baseUrl}}"], "path": ["api", "conversations", "private"] }
          }
        },
        {
          "name": "Enviar mensaje (guarda messageId)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.expect(pm.response.code).to.eql(201));",
            "const d = pm.response.json();",
            "if (d && d.data && d.data.message) { pm.collectionVariables.set('messageId', d.data.message._id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Hola desde Postman!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages", "host": ["{{baseUrl}}"], "path": ["api", "conversations", "{{conversationId}}", "messages"] }
          }
        },
        {
          "name": "Mensajes (con paginacion)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages?limit=50", "host": ["{{baseUrl}}"], "path": ["api", "conversations", "{{conversationId}}", "messages"], "query": [{ "key": "limit", "value": "50" }] } }
        },
        {
          "name": "Editar mensaje",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Mensaje editado\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages/{{messageId}}", "host": ["{{baseUrl}}"], "path": ["api", "conversations", "{{conversationId}}", "messages", "{{messageId}}"] }
          }
        },
        {
          "name": "Respuesta del crack (IA)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Hola crack, como estas?\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/bot-reply", "host": ["{{baseUrl}}"], "path": ["api", "conversations", "{{conversationId}}", "bot-reply"] }
          }
        },
        {
          "name": "Borrar mensaje",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages/{{messageId}}", "host": ["{{baseUrl}}"], "path": ["api", "conversations", "{{conversationId}}", "messages", "{{messageId}}"] } }
        }
      ]
    },
    {
      "name": "Status (Estados)",
      "item": [
        {
          "name": "Publicar estado (guarda statusId)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.expect(pm.response.code).to.eql(201));",
            "const d = pm.response.json();",
            "if (d && d.data && d.data.status) { pm.collectionVariables.set('statusId', d.data.status._id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Mi estado de prueba\",\n  \"content_type\": \"text\",\n  \"background\": \"#00a884\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/status", "host": ["{{baseUrl}}"], "path": ["api", "status"] }
          }
        },
        {
          "name": "Listar estados vigentes",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/status", "host": ["{{baseUrl}}"], "path": ["api", "status"] } }
        },
        {
          "name": "Borrar estado",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.expect(pm.response.code).to.eql(200));"] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/status/{{statusId}}", "host": ["{{baseUrl}}"], "path": ["api", "status", "{{statusId}}"] } }
        }
      ]
    }
  ]
}
