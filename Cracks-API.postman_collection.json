{
  "info": {
    "name": "Cracks API",
    "_postman_id": "cracks-api-collection",
    "description": "Coleccion de la API de Cracks (Trabajo Integrador Final - Back End - UTN). Base local en la variable base_url. Flujo sugerido: Registrar -> Verificar email (pegar el token del mail en la variable verify_token) -> Login (guarda el token automaticamente) -> usar el resto de los endpoints. Las rutas protegidas usan el Bearer token de la coleccion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "contact_user_id",
      "value": ""
    },
    {
      "key": "contact_id",
      "value": ""
    },
    {
      "key": "group_id",
      "value": ""
    },
    {
      "key": "conversation_id",
      "value": ""
    },
    {
      "key": "verify_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Autenticacion",
      "item": [
        {
          "name": "Registrar",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ],
              "raw": "{{base_url}}/api/auth/register"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fernando@cracks.com\",\n  \"password\": \"secret123\",\n  \"display_name\": \"Fernando\",\n  \"phone_number\": \"+54 9 11 5555 0000\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Crea el usuario y envia el email de verificacion."
          },
          "response": []
        },
        {
          "name": "Verificar email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-email"
              ],
              "raw": "{{base_url}}/api/auth/verify-email?token={{verify_token}}",
              "query": [
                {
                  "key": "token",
                  "value": "{{verify_token}}"
                }
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Verifica el email. El token llega en el link del correo."
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ],
              "raw": "{{base_url}}/api/auth/login"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fernando@cracks.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Devuelve user + access_token. El token se guarda solo en la variable token."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('token', json.data.access_token);",
                  "    console.log('Token guardado en la variable token');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Usuarios",
